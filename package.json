{
  "name": "chemag-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for the @chemag toolkit (CLI, core, plugins).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && pnpm test:root",
    "test:root": "vitest run --config vitest.root.config.ts",
    "build": "turbo run build",
    "check-prereqs": "tsx scripts/check-prereqs.ts",
    "gen:diagnostics": "tsx scripts/gen-diagnostics.ts",
    "changeset": "changeset",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
