node_modules/
**/node_modules/
dist/
**/dist/
# Carve-out: the GitHub Action bundle MUST be committed (Actions runtime
# requirement — `runs.main: dist/index.js` cannot install deps at start).
!packages/github-action/dist/
!packages/github-action/dist/**
.cache/
.turbo/
**/.turbo/
# chemag CLI cache (per-workspace runtime artifact; leaks into vscode-extension
# test fixtures when those tests run against the sample-workspace).
**/.chemag/
*.tsbuildinfo
.env
.env.local
coverage/
**/coverage/
.DS_Store

# Per-project Claude Code state: conductor scratch (progress.json, stage
# specs, logs, archives), local settings, scheduled-task state, etc.
# Always personal/transient — never commit.
.claude/

# Compiled test output for the VS Code extension (vscode-test runs the
# .js files written here; the source lives under packages/vscode-extension/test).
packages/vscode-extension/out/
# vsce-produced artifact.
packages/vscode-extension/*.vsix
# vscode-test downloads VS Code into here.
packages/vscode-extension/.vscode-test/
# runTest.js writes a per-run .vscode/settings.json into the fixture so the
# extension finds the chemag CLI; cleaned up after each run, but ignored to
# defend against an interrupted test run leaking it into a commit.
packages/vscode-extension/test/fixtures/sample-workspace/.vscode/
