{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@compounds/*": ["./src/compounds/*"]
    }
  },
  "include": ["src/**/*", "apps/web/**/*", "apps/worker/**/*", "packages/**/*"],
  "exclude": ["**/node_modules", "**/dist", "**/.next", "apps/api/**/*"]
}
