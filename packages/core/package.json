{
  "name": "@chemag/core",
  "version": "0.1.0",
  "description": "Shared engine for the Chem toolkit — types, manifest loader, checks, scaffolder, sync, graph, and the language-plugin interface.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./plugin-interface": {
      "types": "./dist/plugin-interface.d.ts",
      "default": "./dist/plugin-interface.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "default": "./dist/loader.js"
    },
    "./checks": {
      "types": "./dist/checks.d.ts",
      "default": "./dist/checks.js"
    },
    "./import-check": {
      "types": "./dist/import-check.d.ts",
      "default": "./dist/import-check.js"
    },
    "./scaffold": {
      "types": "./dist/scaffold.d.ts",
      "default": "./dist/scaffold.js"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "default": "./dist/sync.js"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "default": "./dist/graph.js"
    },
    "./template-claude-md": {
      "types": "./dist/template-claude-md.d.ts",
      "default": "./dist/template-claude-md.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
