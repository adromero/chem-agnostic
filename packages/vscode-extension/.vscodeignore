# Source — not shipped; only the bundled dist/extension.js + dist/server.js are.
src/**
test/**
out/**

# Build configuration — not needed at runtime.
tsconfig.json
tsconfig.tsbuildinfo
esbuild.config.js
.vscode-test/**

# Tooling artifacts.
node_modules/**
*.tsbuildinfo
.turbo/**

# Source maps — keep the bundles, drop the maps to shrink the .vsix.
dist/**/*.js.map

# Built artifacts that shouldn't be re-packed.
*.vsix
