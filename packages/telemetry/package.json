    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
