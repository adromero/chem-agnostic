{
  "name": "@chemag/cli",
  "version": "0.3.0",
  "description": "Language-agnostic Chem architecture toolkit — analyze, scaffold, and validate chemistry-inspired software architectures.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "chemag": "./bin/chem-ag",
    "chem-ag": "./bin/chem-ag"
  },
  "files": [
    "bin",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map",
    "dist/completions/**",
    "dist/installers/scripts/**"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:version": "node ./scripts/build-version.mjs",
    "build:completions": "node ./scripts/copy-completions.mjs",
    "build:installer-scripts": "node ./scripts/copy-installer-scripts.mjs",
    "prebuild": "npm run build:version",
    "postbuild": "npm run build:completions && npm run build:installer-scripts",
    "build": "tsc -p tsconfig.json",
    "gen:completions": "tsx ./scripts/gen-completions.ts",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "architecture",
    "chem",
    "chemag",
    "analyzer",
    "typescript",
    "python",
    "go",
    "scaffolding"
  ],
  "dependencies": {
    "@chemag/core": "workspace:*",
    "@chemag/lsp-server": "workspace:*",
    "@chemag/mcp-server": "workspace:*",
    "@chemag/plugin-go": "workspace:*",
    "@chemag/plugin-python": "workspace:*",
    "@chemag/plugin-typescript": "workspace:*",
    "@chemag/telemetry": "workspace:*",
    "citty": "^0.2.2",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "fast-xml-parser": "^4.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
