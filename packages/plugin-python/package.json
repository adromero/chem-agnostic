{
  "name": "@chemag/plugin-python",
  "version": "0.1.1",
  "description": "Python language plugin for the Chem toolkit — pure-TypeScript Python import parser plus inferImplements helper.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@chemag/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
