{
  "name": "@chemag/github-action",
  "version": "0.1.1",
  "description": "Official GitHub Action for chemag — runs the chemag CLI on PRs/pushes, posts a sticky comment with violations, and emits a SARIF log for code scanning upload.",
  "license": "MIT",
  "private": true,
  "main": "./dist/index.js",
  "files": [
    "action.yml",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/licenses.txt",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@chemag/core": "workspace:*",
    "@octokit/rest": "^20.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
